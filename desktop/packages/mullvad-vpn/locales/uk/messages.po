#. The title for the obfuscation method selector.
msgctxt "anti-censorship-view"
msgid "Method"
msgstr "Метод"

#. Second paragraph of description text in anti-censorship view
msgctxt "anti-censorship-view"
msgid "Please note that these methods do not improve performance, and may increase system utilization and battery consumption."
msgstr "Зауважте, що ці методи не покращують продуктивності й можуть збільшити навантаження на систему та споживання заряду батареї."

#. First paragraph of description text in anti-censorship view
msgctxt "anti-censorship-view"
msgid "These methods may be useful in situations where you are blocked from reaching Mullvad. When \"Automatic\" is selected, the app will attempt all methods until one works."
msgstr "Ці методи можуть бути корисними в ситуаціях, коли у вас заблоковано доступ до Mullvad. Якщо вибрано «Автоматично», застосунок намагатиметься використовувати всі методи, доки один із них не спрацює."

msgctxt "api-access-methods-view"
msgid "Add method"
msgstr "Додавання методу"

msgctxt "api-access-methods-view"
msgid "Adding a new API access method also tests it."
msgstr "Під час додавання нового методу доступу до API також виконується його перевірка."

msgctxt "api-access-methods-view"
msgid "API reachable"
msgstr "Є доступ до API"

msgctxt "api-access-methods-view"
msgid "API reachable, adding method…"
msgstr "Є доступ до API, додаємо метод…"

msgctxt "api-access-methods-view"
msgid "API reachable, saving method…"
msgstr "Є доступ до API, зберігаємо метод…"

msgctxt "api-access-methods-view"
msgid "API unreachable"
