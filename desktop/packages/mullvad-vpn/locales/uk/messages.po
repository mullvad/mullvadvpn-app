msgctxt "in-app-notifications"
msgid "Click here to update"
msgstr "Натисніть тут, щоб оновити"

#. Notification subtitle when the installer download failed.
msgctxt "in-app-notifications"
msgid "Could not download installer."
msgstr "Не вдалося завантажити інсталятор."

#. Generic notification subtitle when the app upgrade failed.
msgctxt "in-app-notifications"
msgid "Could not upgrade the app."
msgstr "Не вдалось оновити застосунок."

#. Notification title when app upgrade is verifying the installer.
msgctxt "in-app-notifications"
msgid "DOWNLOAD COMPLETE! VERIFYING..."
msgstr "ЗАВАНТАЖЕННЯ ЗАВЕРШЕНО! ПЕРЕВІРЯЄМО…"

#. Notification title when the installer download failed.
msgctxt "in-app-notifications"
msgid "DOWNLOAD FAILED"
msgstr "ПОМИЛКА ЗАВАНТАЖЕННЯ"

#. Generic notification title when app upgrade is downloading the installer.
msgctxt "in-app-notifications"
msgid "DOWNLOADING UPDATE..."
msgstr "ЗАВАНТАЖЕННЯ ОНОВЛЕННЯ…"

#. Notification title when the app upgrade is in progress.
#. Available placeholders:
#. - %(appUpgradeDownloadProgressValue)s: The download progress value.
msgctxt "in-app-notifications"
msgid "DOWNLOADING UPDATE... %(appUpgradeDownloadProgressValue)s%%"
msgstr "ЗАВАНТАЖЕННЯ ОНОВЛЕННЯ... %(appUpgradeDownloadProgressValue)s%%"

#. The in-app banner displayed to the user when the app update is available.
msgctxt "in-app-notifications"
msgid "Install the latest app version to stay up to date."
msgstr "Установіть останню версію, щоб нічого не пропустити."

#. Notification title when the installer failed.
msgctxt "in-app-notifications"
msgid "INSTALLER FAILED"
msgstr "ПОМИЛКА ІНСТАЛЯТОРА"

msgctxt "in-app-notifications"
msgid "NETWORK TRAFFIC MIGHT BE LEAKING"
msgstr "МОЖЛИВИЙ ВИТІК МЕРЕЖЕВОГО ТРАФІКУ"

msgctxt "in-app-notifications"
msgid "NEW DEVICE CREATED"
msgstr "СТВОРЕНО НОВИЙ ПРИСТРІЙ"

msgctxt "in-app-notifications"
msgid "NEW VERSION INSTALLED"
msgstr "УСТАНОВЛЕНО НОВУ ВЕРСІЮ"

msgctxt "in-app-notifications"
msgid "Please quit and restart the app."
msgstr "Вийдіть і перезапустіть застосунок."

#. Notification title when the app upgrade is ready to install.
msgctxt "in-app-notifications"
msgid "READY TO INSTALL UPDATE"
msgstr "ОНОВЛЕННЯ ГОТОВЕ ДО ВСТАНОВЛЕННЯ"

#. Accessibility label for the button to retry download of the installer.
msgctxt "in-app-notifications"
msgid "Retry download of the installer"
msgstr "Повторити спробу завантаження інсталятора"

#. Accessibility label for the button to retry the installation.
msgctxt "in-app-notifications"
msgid "Retry installation"
msgstr "Повторити спробу встановлення"

#. Button label to send a problem report.
msgctxt "in-app-notifications"
msgid "Send problem report"
msgstr "Надіслати звіт про проблему"

#. Notification subtitle when the installer verification failed.
msgctxt "in-app-notifications"
msgid "The installer could not be verified."
msgstr "Не вдалося перевірити інсталятор."

#. Notification subtitle when the installer failed.
msgctxt "in-app-notifications"
msgid "The installer did not complete successfully."
msgstr "Інсталятор не завершив роботу."

#. Notification subtitle when the installer failed.
msgctxt "in-app-notifications"
msgid "The installer did not start successfully."
msgstr "Не вдалося запустити інсталятор."

#. Notification subtitle indicating the user is using an unsupported port for WireGuard.
#. Available placeholders:
#. %(wireGuard)s - Will be replaced with WireGuard
msgctxt "in-app-notifications"
msgid "The selected %(wireGuard)s port is not supported, please <a>change it under VPN settings.</a>"
msgstr "Вибраний порт %(wireGuard)s не підтримується, <a>змініть його в налаштуваннях VPN.</a>"

#. Notification text when a new device has been created.
#. Available placeholders:
#. - %(deviceName)s: Name of created device.
msgctxt "in-app-notifications"
msgid "This device is now named <em>%(deviceName)s</em>. See more under <a>Manage devices</a> in Account."
msgstr "Пристрою присвоєно ім’я <em>%(deviceName)s</em>. Докладніше в розділі <a>«Керування пристроями»</a>."

#. The in-app banner displayed to the user when the app beta update is
#. available.
#. Available placeholders:
#. %(version)s - The version number of the new beta version.
msgctxt "in-app-notifications"
msgid "Try out the newest beta version (%(version)s)."
msgstr "Спробуйте нашу найновішу бета-версію (%(version)s)."

msgctxt "in-app-notifications"
msgid "UNSUPPORTED VERSION"
msgstr "НЕПІДТРИМУВАНА ВЕРСІЯ"

msgctxt "in-app-notifications"
msgid "UPDATE AVAILABLE"
msgstr "ДОСТУПНЕ ОНОВЛЕННЯ"

#. Generic notification title when the app upgrade failed.
msgctxt "in-app-notifications"
msgid "UPDATE FAILED"
msgstr "ПОМИЛКА ОНОВЛЕННЯ"

#. Notification title when app upgrade is ready for the user to launch the installer.
msgctxt "in-app-notifications"
msgid "VERIFICATION COMPLETE! INSTALLER READY!"
msgstr "ПЕРЕВІРКУ ПРОЙДЕНО! ІНСТАЛЯТОР ГОТОВИЙ!"

#. Notification title when app upgrade is launching the installer.
msgctxt "in-app-notifications"
msgid "VERIFICATION COMPLETE! LAUNCHING INSTALLER..."
msgstr "ПЕРЕВІРКУ ПРОЙДЕНО! ЗАПУСК ІНСТАЛЯТОРА…"

#. Notification title when the installer verification failed.
msgctxt "in-app-notifications"
msgid "VERIFICATION FAILED"
msgstr "ПОМИЛКА ПЕРЕВІРКИ"

#. Status text app is trying to connect to the system service.
msgctxt "launch-view"
msgid "Connecting to Mullvad system service..."
msgstr "Підключення до системного сервісу Mullvad…"

#. Button label for opening dialog with troubleshooting details.
msgctxt "launch-view"
msgid "Details"
msgstr "Відомості"

#. List item in troubleshooting modal advising user disable third party antivirus.
msgctxt "launch-view"
msgid "Disabling third party antivirus software"
msgstr "Вимкнути сторонні антивірусні програми"

#. Status text shown when app fails to start.
msgctxt "launch-view"
msgid "Failed to start the app, please try again or click “Details” for more info"
msgstr "Помилка запуску застосунку. Повторіть спробу або натисніть «Відомості», щоб дізнатися більше"

#. Message in troubleshooting modal advising user to send a problem report if the steps do not work.
msgctxt "launch-view"
msgid "If these steps do not work please send a problem report."
msgstr "Якщо це не допоможе, надішліть звіт про проблему."

#. Message in launch view when the background process permissions have been revoked.
msgctxt "launch-view"
msgid "Permission for the Mullvad VPN service has been revoked. Please go to System Settings and allow Mullvad VPN under the “Allow in the Background” setting."
msgstr "Дозвіл для сервісу Mullvad VPN відкликано. Перейдіть у налаштування системи й увімкніть параметр «Дозволити у фоновому режимі» для Mullvad VPN."

#. List item in troubleshooting modal advising user to reinstall the app.
msgctxt "launch-view"
msgid "Reinstalling the app"
msgstr "Перевстановити застосунок"

#. List item in troubleshooting modal advising user to restart background process.
msgctxt "launch-view"
msgid "Restarting the Mullvad background process"
msgstr "Перезапустити фоновий процес Mullvad"

#. List item in troubleshooting modal instructing user how to restart the background process.
msgctxt "launch-view"
msgid "Restarting the Mullvad background process by clicking \"Back\", then \"Try again\""
msgstr "Перезапустити фоновий процес Mullvad, натиснувши «Назад», а потім — «Повторити»"

#. List item in troubleshooting modal advising user to restart their computer.
msgctxt "launch-view"
msgid "Restarting your computer"
msgstr "Перезапустити комп’ютер"

#. Button label for sending a problem report.
msgctxt "launch-view"
msgid "Send problem report"
msgstr "Надіслати звіт про проблему"

#. Status text shown when app is starting.
msgctxt "launch-view"
msgid "Starting up...."
msgstr "Запуск…"

#. Message in troubleshooting modal when the background process failed to start.
msgctxt "launch-view"
msgid "The Mullvad background process failed to start. The background process is responsible for the security, kill switch, and the VPN tunnel. Please try:"
msgstr "Не вдалося запустити фоновий процес Mullvad. Фоновий процес відповідає за безпеку, аварійний вимикач і VPN-тунель. Спробуйте виконати такі дії:"

#. Button label for trying to restart the daemon again.
msgctxt "launch-view"
msgid "Try again"
msgstr "Повторити"

#. Message in launch view when the mullvad service cannot be contacted.
msgctxt "launch-view"
msgid "Unable to contact the Mullvad system service, your connection might be unsecure. Please troubleshoot or send a problem report by clicking the \"Learn more\" button."
msgstr "Не вдалося зв’язатись із системною службою Mullvad. Імовірно, ваше підключення не захищене. Усуньте неполадки або надішліть звіт про проблему, натиснувши «Докладніше»."

#. This is used for appending information about a location.
#. E.g. "Gothenburg (Entry)" if Gothenburg has been selected as the entrypoint.
#. Available placeholders:
#. %(location)s - Translated location name
#. %(info)s - Information about the location
msgctxt "locations-feature"
msgid "%(location)s (%(info)s)"
msgstr "%(location)s (%(info)s)"

msgctxt "locations-feature"
msgid "Disabling recents will also clear history."
msgstr "Вимкнення нещодавнього вибору призведе до очищення історії."

msgctxt "locations-feature"
msgid "Entry"
msgstr "Вхід"

msgctxt "locations-feature"
msgid "Exit"
msgstr "Вихід"

#. This is a warning message shown when the app is blocking the users
#. internet connection while logged out.
#. Available placeholder:
#. %(lockdownModeSettingName)s - The translation of "Lockdown mode"
msgctxt "login-view"
msgid "<b>%(lockdownModeSettingName)s</b> is enabled. Disable it to unblock your connection."
msgstr "Увімкнено опцію <b>%(lockdownModeSettingName)s</b>. Щоб розблокувати з’єднання, вимкніть її."

msgctxt "login-view"
msgid "Account created"
msgstr "Обліковий запис створено"

msgctxt "login-view"
msgid "Checking account number"
msgstr "Перевірка номера облікового запису"

#. Text in button that allows user to create a new account.
msgctxt "login-view"
msgid "Create a new account"
msgstr "Створити обліковий запис"

#. Button which confirms the action to create a new account.
msgctxt "login-view"
msgid "Create new account"
msgstr "Створити обліковий запис"

msgctxt "login-view"
msgid "Creating account..."
msgstr "Створення облікового запису…"

#. Text that asks the user if they really want to create a new account.
msgctxt "login-view"
msgid "Do you want to create a new account?"
msgstr "Створити новий обліковий запис?"

#. Text that asks the user if they really want to remove the saved account.
msgctxt "login-view"
msgid "Do you want to remove the saved account number?"
msgstr "Вилучити збережений номер облікового запису?"

msgctxt "login-view"
msgid "Enter your account number"
msgstr "Введіть номер облікового запису"

msgctxt "login-view"
msgid "Error"
msgstr "Помилка"

msgctxt "login-view"
msgid "Failed to create account"
msgstr "Не вдалося створити обліковий запис"

msgctxt "login-view"
msgid "Finishing upgrade."
msgstr "Завершення оновлення."

#. Error message shown above login input when trying to login with a
#. non-existent account number.
msgctxt "login-view"
msgid "Invalid account number"
msgstr "Недійсний номер облікового запису"

msgctxt "login-view"
msgid "Logged in"
msgstr "Виконано вхід"

msgctxt "login-view"
msgid "Logging in..."
msgstr "Виконується вхід…"

#. Label for the login button.
msgctxt "login-view"
msgid "Login"
msgstr "Вхід"

msgctxt "login-view"
msgid "Login failed"
msgstr "Помилка входу"

#. Text shown between two horizontal lines above the "create account" button.
#. In this context it is used to separate the users alternative of logging in
#. or creating a new account, "Login or Create a new account".
msgctxt "login-view"
msgid "Or"
msgstr "Або"

#. This is a warning message shown when the app is blocking the users
#. internet connection while logged out.
msgctxt "login-view"
msgid "Our kill switch is currently blocking your connection."
msgstr "Аварійний вимикач блокує з’єднання."

msgctxt "login-view"
msgid "Please wait"
msgstr "Зачекайте"

#. Text that informs the user about the consequences of clearing the saved
#. account number.
msgctxt "login-view"
msgid "Removing the saved account number from this device cannot be undone."
msgstr "Вилучення збереженого номера облікового запису з пристрою не можна скасувати."

#. Error message shown above login input when trying to login to an account
#. with too many registered devices.
msgctxt "login-view"
msgid "Too many devices"
msgstr "Забагато пристроїв"

msgctxt "login-view"
msgid "Unknown error"
msgstr "Невідома помилка…"

msgctxt "login-view"
msgid "Upgrading..."
msgstr "Оновлення…"

msgctxt "login-view"
msgid "Valid account number"
msgstr "Дійсний номер облікового запису"

#. Text that informs the users about consequences of creating a new account.
msgctxt "login-view"
msgid "You already have a saved account number, by creating a new account the saved account number will be removed from this device. This cannot be undone."
msgstr "У вас уже є збережений номер облікового запису. Після створення нового його буде видалено. Цю дію не можна скасувати."

#. The title for the LWO port selector.
msgctxt "lwo-settings-view"
msgid "Port"
msgstr "Порт"

#. Text showing currently selected port.
#. Available placeholders:
#. %(port)s - Can be either a number between 1 and 65535 or the text "Automatic".
msgctxt "lwo-settings-view"
msgid "Port: %(port)s"
msgstr "Порт: %(port)s"

msgctxt "lwo-settings-view"
msgid "The automatic setting will randomly choose from the valid port ranges shown below."
msgstr "В автоматичному режимі порт у випадковому порядку вибирається з допустимих діапазонів, зазначених нижче."

msgctxt "lwo-settings-view"
msgid "The custom port can be any value inside the valid ranges: %(portRanges)s."
msgstr "Користувацький порт може мати будь-яке значення в межах дійсних діапазонів: %(portRanges)s."

#. Text describing the valid port ranges for a port selector.
#. Available placeholders:
#. %(portRanges)s - will be replaced with a comma-separated list of port ranges
msgctxt "lwo-settings-view"
msgid "Valid ranges: %(portRanges)s"
msgstr "Допустимі діапазони: %(portRanges)s"

#. Title label in navigation bar
msgctxt "navigation-bar"
msgid "API access"
msgstr "Доступ до API"

#. The system notification displayed to the user when the account credit is close to expiry.
#. Available placeholder:
#. %(duration)s - remaining time, e.g. "2 days"
msgctxt "notifications"
msgid "Account credit expires in %(duration)s. Buy more credit."
msgstr "Баланс облікового запису закінчується за %(duration)s. Поповніть баланс."

msgctxt "notifications"
msgid "Account is out of time"
msgstr "В обліковому записі завершився час"

msgctxt "notifications"
msgid "App is out of sync. Please quit and restart."
msgstr "Застосунок не синхронізовано. Закрийте його й перезапустіть."

#. The system notification that notifies the user when a beta update is
#. available.
#. Available placeholders:
#. %(version)s - The version number of the new beta version.
msgctxt "notifications"
msgid "Beta update available. Try out the newest beta version (%(version)s)."
msgstr "Доступне оновлення бета-версії. Спробуйте найновішу версію (%(version)s)."

msgctxt "notifications"
msgid "Buy more"
msgstr "Купити ще"

msgctxt "notifications"
msgid "Connected"
msgstr "Підключено"

#. The message showed when a server has been connected to.
#. Available placeholder:
#. %(location) - name of the server location we're connected to (e.g. "se-got-003")
msgctxt "notifications"
msgid "Connected to %(location)s"
msgstr "Підключено до: %(location)s"

msgctxt "notifications"
msgid "Connecting"
msgstr "Підключення"

#. The message showed when a server is being connected to.
#. Available placeholder:
#. %(location) - name of the server location we're connecting to (e.g. "se-got-003")
msgctxt "notifications"
msgid "Connecting to %(location)s"
msgstr "Підключення до: %(location)s"

msgctxt "notifications"
msgid "Connection might be unsecured. App lost contact with system service, please troubleshoot."
msgstr "Можливо, підключення не захищене. Застосунок втратив зв’язок із системною службою, усуньте неполадки."

msgctxt "notifications"
msgid "Could not configure IPv6. Disable it in the app or enable it on your device."
msgstr "Не вдалося налаштувати IPv6. Вимкніть його в застосунку або увімкніть на пристрої."

msgctxt "notifications"
msgid "Disconnected and unsecure"
msgstr "Відключено й не захищено"

msgctxt "notifications"
msgid "Failed to enable split tunneling."
msgstr "Не вдалося ввімкнути роздільне тунелювання."

msgctxt "notifications"
msgid "Failed to enable split tunneling. Please try reconnecting or disable split tunneling."
msgstr "Не вдалося ввімкнути роздільне тунелювання. Спробуйте перепідключитися або вимкніть роздільне тунелювання."

#. Label for the system notification when the app encountered an error
#. and will block network traffic until the error is resolved.
#. Label for the in-app banner when the app encountered an error
msgctxt "notifications"
msgid "Failed to start %(splitTunneling)s. To unblock network traffic, disable split tunneling."
msgstr "Не вдається запустити %(splitTunneling)s. Щоб розблокувати мережевий трафік, вимкніть роздільне тунелювання."

#. Label for notification when IPv4 is not available.
msgctxt "notifications"
msgid "IPv4 is not available, please try changing Device IP version setting."
msgstr "Протокол IPv4 недоступний, спробуйте змінити налаштування версії IP на пристрої."

#. Label for notification when IPv6 is not available.
msgctxt "notifications"
msgid "IPv6 is not available, please try changing Device IP version setting."
msgstr "Протокол IPv6 недоступний, спробуйте змінити налаштування версії IP на пристрої."

msgctxt "notifications"
msgid "Lockdown mode active, connection blocked"
msgstr "Режим блокування активний, з’єднання заблоковано"

msgctxt "notifications"
msgid "No servers match your settings, try changing server or other settings."
msgstr "Жоден сервер не відповідає налаштуванням, спробуйте змінити сервер чи налаштування."

#. A link in the in-app banner to encourage the user to update the app.
#. The in-app banner is is displayed to the user when the running app becomes unsupported.
msgctxt "notifications"
msgid "Please click here to update now"
msgstr "Натисніть тут, щоб оновити зараз"

msgctxt "notifications"
msgid "Reconnecting"
msgstr "Перепідключення"

msgctxt "notifications"
msgid "The apps excluded with %(splitTunneling)s might not work properly right now."
msgstr "Застосунки, виключені за допомогою функції «%(splitTunneling)s», можуть зараз працювати неправильно."

msgctxt "notifications"
msgid "Unable to apply firewall rules."
msgstr "Не вдалося застосувати правила брандмауера."

msgctxt "notifications"
msgid "Unable to apply firewall rules. Try temporarily disabling any third-party antivirus or security software."
msgstr "Не вдалося застосувати правила брандмауера. Спробуйте тимчасово вимкнути сторонній антивірус або захисне ПЗ."

msgctxt "notifications"
msgid "Unable to apply firewall rules. Try updating your kernel."
msgstr "Не вдалося застосувати правила брандмауера. Спробуйте оновити ядро."

msgctxt "notifications"
msgid "Unable to block all network traffic. Please troubleshoot or send a problem report."
msgstr "Не вдалося заблокувати весь мережевий трафік. Усуньте неполадки або надішліть звіт про проблему."

msgctxt "notifications"
msgid "Unable to block all network traffic. Try temporarily disabling any third-party antivirus or security software or send a problem report."
msgstr "Не вдалося заблокувати весь мережевий трафік. Спробуйте тимчасово вимкнути сторонній антивірус або захисне ПЗ чи надішліть звіт про проблему."

msgctxt "notifications"
msgid "Unable to block all network traffic. Try updating your kernel or send a problem report."
msgstr "Не вдалося заблокувати весь мережевий трафік. Спробуйте оновити ядро або надішліть звіт про проблему."

msgctxt "notifications"
msgid "Unable to communicate with Mullvad kernel driver. Try reconnecting or send a problem report."
msgstr "Не вдалося встановити зв’язок із драйвером ядра Mullvad. Спробуйте перепідключитися або надішліть звіт про проблему."

msgctxt "notifications"
msgid "Unable to resolve host of custom tunnel. Try changing your settings."
msgstr "Не вдається перетворити адресу хоста користувацького тунелю на IP. Змініть налаштування та спробуйте знову."

msgctxt "notifications"
msgid "Unable to set system DNS server. Please send a problem report."
msgstr "Не вдалося встановити системний DNS-сервер. Надішліть звіт про проблему."

msgctxt "notifications"
msgid "Unable to start tunnel connection. Please send a problem report."
msgstr "Не вдалося запустити тунельне з’єднання. Надішліть звіт про проблему."

msgctxt "notifications"
msgid "Unable to start tunnel connection. This could be because of conflicts with VMware, please troubleshoot."
msgstr "Не вдалося запустити тунельне з’єднання. Це може бути через конфлікти з VMware, усуньте неполадки."

msgctxt "notifications"
msgid "Update available. Install the latest app version to stay up to date"
msgstr "Доступне оновлення. Установіть останню версію, щоб нічого не пропустити"

msgctxt "notifications"
msgid "Upgrade"
msgstr "Оновити"

msgctxt "notifications"
msgid "Your device is offline. The tunnel will automatically connect once your device is back online."
msgstr "Ваш пристрій офлайн. Тунель автоматично підключиться, щойно він знову буде онлайн."

#. The in-app banner which is displayed to the user when the running app becomes unsupported.
msgctxt "notifications"
msgid "Your privacy might be at risk with this unsupported app version."
msgstr "Ваша конфіденційність може бути під загрозою через непідтримувану версію застосунку."

#. The system notification which is displayed to the user when the running app becomes unsupported.
msgctxt "notifications"
msgid "Your privacy might be at risk with this unsupported app version. Please update now."
msgstr "Ваша конфіденційність може бути під загрозою через цю непідтримувану версію застосунку. Оновіть її."

#. Cancel button label for voucher redemption.
msgctxt "redeem-voucher-alert"
msgid "Cancel"
msgstr "Скасувати"

#. Input field label for voucher code.
msgctxt "redeem-voucher-alert"
msgid "Enter voucher code"
msgstr "Введіть код ваучера"

#. Button label for redeeming a voucher.
msgctxt "redeem-voucher-alert"
msgid "Redeem voucher"
msgstr "Використати ваучер"

msgctxt "redeem-voucher-view"
msgid "An error occurred."
msgstr "Сталася помилка."

msgctxt "redeem-voucher-view"
msgid "It looks like you’ve entered an account number instead of a voucher code. If you would like to change the active account, please log out first."
msgstr "Схоже, ви ввели номер облікового запису замість коду ваучера. Якщо хочете змінити активний обліковий запис, спочатку вийдіть з облікового запису."

#. Button label for voucher redemption.
msgctxt "redeem-voucher-view"
msgid "Redeem"
msgstr "Використати"

msgctxt "redeem-voucher-view"
msgid "Verifying voucher..."
msgstr "Ваучер перевіряється…"

msgctxt "redeem-voucher-view"
msgid "Voucher code has already been used."
msgstr "Код ваучера вже використано."

msgctxt "redeem-voucher-view"
msgid "Voucher code is invalid."
msgstr "Недійсний код ваучера."

msgctxt "redeem-voucher-view"
msgid "Voucher was successfully redeemed."
msgstr "Ваучер використано."

#. Title label in navigation bar
msgctxt "select-language-nav"
msgid "Select language"
msgstr "Вибір мови"

#. Title label in navigation bar
msgctxt "select-location-nav"
msgid "Select location"
msgstr "Вибір розташування"

#. Message shown when the user has no custom lists.
#. Instructs the user how to create a custom list.
msgctxt "select-location-view"
msgid "Add a custom list by clicking the “+” icon"
msgstr "Додайте користувацький список, натиснувши «+»"

msgctxt "select-location-view"
msgid "All locations"
msgstr "Усі розташування"

#. Message shown in the custom list section when the user has at least one custom list.
#. Instructs the user how to add locations to the custom list.
msgctxt "select-location-view"
msgid "Click “+“ on a location to add it to a list"
msgstr "Натисніть «+» на розташуванні, щоб додати його до списку"

msgctxt "select-location-view"
msgid "Custom lists"
msgstr "Користувацькі списки"

msgctxt "select-location-view"
msgid "Disable recents"
msgstr "Вимкнути нещодавні"

#. Label for custom lists that don't have any locations added to them yet.
msgctxt "select-location-view"
msgid "Empty"
msgstr "Порожній"

msgctxt "select-location-view"
msgid "Enable recents"
msgstr "Увімкнути нещодавні"

msgctxt "select-location-view"
msgid "Entry"
msgstr "Вхід"

msgctxt "select-location-view"
msgid "Exit"
msgstr "Вихід"

msgctxt "select-location-view"
msgid "Filtered:"
msgstr "Відфільтровано:"

#. Message shown when the user has no recent locations.
msgctxt "select-location-view"
msgid "No recent selection history"
msgstr "Немає нещодавньої історії вибору"

#. Label for indicator that shows that obfuscation is being used as a filter.
#. Available placeholders:
#. %(obfuscation)s - type of obfuscation in use
msgctxt "select-location-view"
msgid "Obfuscation: %(obfuscation)s"
msgstr "Обфускація: %(obfuscation)s"

msgctxt "select-location-view"
msgid "Open %(daita)s settings"
msgstr "Відкрити налаштування %(daita)s"

msgctxt "select-location-view"
msgid "Providers: %(numberOfProviders)d"
msgstr "Провайдери: %(numberOfProviders)d"

#. Title for section showing recently used locations.
msgctxt "select-location-view"
msgid "Recents"
msgstr "Нещодавні"

msgctxt "select-location-view"
msgid "Setting: %(settingName)s"
msgstr "Налаштування: %(settingName)s"

#. Text showing how many locations are currently shown out of the total number of locations, e.g. "Showing 5 of 250"
#. Available placeholders:
#. %(visibleRelays)s: The number of relays currently shown
#. %(totalRelays)s: The total number of relays
msgctxt "select-location-view"
msgid "Showing %(visibleRelays)s of %(totalRelays)s"
msgstr "Показано %(visibleRelays)s з %(totalRelays)s"

msgctxt "select-location-view"
msgid "The entry server for %(multihop)s is currently overridden by %(daita)s. To select an entry server, please first enable “%(directOnly)s” or disable \"%(daita)s\" in the settings."
msgstr "Сервер входу для функції «%(multihop)s» зараз перевизначено функцією %(daita)s. Щоб вибрати сервер входу, спочатку ввімкніть «%(directOnly)s» або вимкніть «%(daita)s» у налаштуваннях."

msgctxt "settings-import"
msgid "Clear all overrides"
msgstr "Видалити всі перевизначення"

msgctxt "settings-import"
msgid "Clear all overrides?"
msgstr "Видалити всі перевизначення?"

msgctxt "settings-import"
msgid "Clearing the imported overrides changes the server IPs, in the Select location view, back to default."
msgstr "Видалення імпортованих перевизначень змінює IP-адреси серверів у розділі «Вибір розташування» до значень за замовчуванням."

msgctxt "settings-import"
msgid "If you are having issues connecting to VPN servers, please contact support."
msgstr "У разі проблем із підключенням до серверів VPN зверніться до служби підтримки."

msgctxt "settings-import"
msgid "Import file"
msgstr "Імпортувати файл"

msgctxt "settings-import"
msgid "Import files or text with new IP addresses for the servers in the Select location view."
msgstr "Імпорт файлів або тексту з новими IP-адресами для серверів у розділі «Вибір розташування»."

msgctxt "settings-import"
msgid "Import of file %(fileName)s was successful, overrides are now active."
msgstr "Файл %(fileName)s імпортовано, перевизначення активні."

msgctxt "settings-import"
msgid "Import of file %(fileName)s was unsuccessful, please try again."
msgstr "Не вдалось імпортувати файл %(fileName)s, повторіть спробу."

msgctxt "settings-import"
msgid "Import of text was successful, overrides are now active."
msgstr "Текст імпортовано, перевизначення активні."

msgctxt "settings-import"
msgid "Import of text was unsuccessful, please try again."
msgstr "Не вдалось імпортувати текст, повторіть спробу."

msgctxt "settings-import"
msgid "IMPORT SUCCESSFUL"
msgstr "ІМПОРТ ВИКОНАНО"

#. Title label in navigation bar
msgctxt "settings-import"
msgid "Import via text"
msgstr "Імпортувати через текст"

msgctxt "settings-import"
msgid "NO OVERRIDES IMPORTED"
msgstr "ПЕРЕВИЗНАЧЕННЯ НЕ ІМПОРТОВАНО"

msgctxt "settings-import"
msgid "On some networks, where various types of censorship are being used, our server IP addresses are sometimes blocked."
msgstr "У деяких мережах, де використовуються різні типи цензури, IP-адреси наших серверів інколи блокуються."

msgctxt "settings-import"
msgid "OVERRIDES ACTIVE"
msgstr "ПЕРЕВИЗНАЧЕННЯ АКТИВНІ"

#. Title label in navigation bar. This is for a feature that lets
#. users import server IP settings.
msgctxt "settings-import"
msgid "Server IP override"
msgstr "Перевизначення IP-адреси сервера"

msgctxt "settings-import"
msgid "To circumvent this you can import a file or a text, provided by our support team, with new IP addresses that override the default addresses of the servers in the Select location view."
msgstr "Щоб обійти це, ви можете імпортувати файл або текст, наданий нашою службою підтримки, з новими IP-адресами, які перевизначать адреси серверів за замовчуванням у розділі «Вибір розташування»."

#. Navigation button to the 'API access methods' view
msgctxt "settings-view"
msgid "API access"
msgstr "Доступ до API"

#. Navigation button to the 'App info' view
msgctxt "settings-view"
msgid "App info"
msgstr "Інформація про застосунок"

msgctxt "settings-view"
msgid "Multihop"
msgstr "Подвійний VPN"

#. Title label in navigation bar
msgctxt "settings-view"
msgid "Settings"
msgstr "Налаштування"

#. Navigation button to the 'Support' view
msgctxt "settings-view"
msgid "Support"
msgstr "Підтримка"

#. Label for the app info list item indicating that an update is available and can be downloaded
msgctxt "settings-view"
msgid "Update available"
msgstr "Доступне оновлення"

#. Navigation button to the 'User interface settings' view
msgctxt "settings-view"
msgid "User interface settings"
msgstr "Налаштування інтерфейсу"

#. Navigation button to the 'VPN settings' view
msgctxt "settings-view"
msgid "VPN settings"
msgstr "Налаштування VPN"

msgctxt "split-tunneling-view"
msgid "%(applicationName)s is problematic and can’t be excluded from the VPN tunnel."
msgstr "Застосунок %(applicationName)s є проблемним і не може бути виключений із VPN-тунелю."

#. Information about split tunneling not being supported on the system.
#. Available placeholders:
#. %(splitTunneling)s - will be replaced with Split tunneling
msgctxt "split-tunneling-view"
msgid "%(splitTunneling)s is not supported by your system."
msgstr "%(splitTunneling)s не підтримується вашою системою."

msgctxt "split-tunneling-view"
msgid "Add"
msgstr "Додати"

msgctxt "split-tunneling-view"
msgid "All apps"
msgstr "Усі застосунки"

msgctxt "split-tunneling-view"
msgid "Choose the apps you want to exclude from the VPN tunnel."
msgstr "Виберіть застосунки, які ви хочете виключити з VPN-тунелю."

#. Link for learning more
msgctxt "split-tunneling-view"
msgid "Click here to learn more"
msgstr "Натисніть тут, щоб дізнатися більше"

msgctxt "split-tunneling-view"
msgid "Click on an app to launch it. Its traffic will bypass the VPN tunnel until you close it."
msgstr "Клацніть на застосунку, щоб запустити його. Його трафік обходитиме VPN-тунель, доки ви його не закриєте."

msgctxt "split-tunneling-view"
msgid "Enabled \"Full disk access\" and still having issues?"
msgstr "Увімкнено «Повний доступ до диска», а проблеми не зникли?"

msgctxt "split-tunneling-view"
msgid "Excluded apps"
msgstr "Виключені застосунки"

#. Button label for browsing applications with split tunneling.
msgctxt "split-tunneling-view"
msgid "Find another app"
msgstr "Знайти інший застосунок"

msgctxt "split-tunneling-view"
msgid "If it’s already running, close %(applicationName)s before launching it from here. Otherwise it might not be excluded from the VPN tunnel."
msgstr "Якщо застосунок уже запущено, закрийте %(applicationName)s і лише після цього запускайте його звідси. Інакше його не можна буде виключити з VPN-тунелю."

#. Button label for launching an application with split tunneling.
msgctxt "split-tunneling-view"
msgid "Launch"
msgstr "Запустити"

msgctxt "split-tunneling-view"
msgid "Open System Settings"
msgstr "Відкрити налаштування системи"

#. This error message is shown if the user tries to launch a Linux desktop
#. entry file that doesn't contain the required 'Exec' value.
msgctxt "split-tunneling-view"
msgid "Please send a problem report."
msgstr "Надішліть звіт про проблему."

#. This error message is shown if the user tries to launch an app that
#. doesn't exist.
#. This error message is shown if an application fails during startup.
msgctxt "split-tunneling-view"
msgid "Please try again or send a problem report."
msgstr "Спробуйте ще раз або надішліть звіт про проблему."

msgctxt "split-tunneling-view"
msgid "Restart Mullvad Service"
msgstr "Перезапустити сервіс Mullvad"

#. Information about split tunneling being unavailable due to
#. missing support in the user's operating system.
#. Available placeholders:
#. %(splitTunneling)s - will be replaced with Split tunneling
msgctxt "split-tunneling-view"
msgid "To use %(splitTunneling)s, please update to a Linux kernel version that supports cgroup v2."
msgstr "Щоб використовувати %(splitTunneling)s, оновіть ядро Linux до версії, що підтримує cgroup v2."

msgctxt "split-tunneling-view"
msgid "To use split tunneling please enable “Full disk access” for “Mullvad VPN” in the macOS system settings."
msgstr "Для використання роздільного тунелювання ввімкніть «Повний доступ до диска» для Mullvad VPN у системних налаштуваннях macOS."

#. Error message showed in a dialog when an application fails to launch.
msgctxt "split-tunneling-view"
msgid "Unable to launch selection. %(detailedErrorMessage)s"
msgstr "Не вдалося запустити вибір. %(detailedErrorMessage)s"

#. Button label for continuing problem report submission with an outdated app version.
msgctxt "support-view"
msgid "Continue anyway"
msgstr "Усе одно продовжити"

#. Button text to edit the message after a failed attempt to send the problem report.
msgctxt "support-view"
msgid "Edit message"
msgstr "Редагувати повідомлення"

msgctxt "support-view"
msgid "Failed to send"
msgstr "Помилка надсилання"

#. Link to the webpage
msgctxt "support-view"
msgid "FAQs & Guides"
msgstr "Поширені запитання і посібники"

#. The message displayed to the user after submitting the problem report, given that the user left his or her email for us to reach back.
#. Available placeholders:
#. %(email)s
msgctxt "support-view"
msgid "If needed we will contact you at %(email)s"
msgstr "За потреби ми зв’яжемося з вами за адресою %(email)s"

msgctxt "support-view"
msgid "If you exit the form and try again later, the information you already entered will still be here."
msgstr "Якщо ви вийдете з форми й повернетеся пізніше, введена інформація збережеться."

#. Title label in navigation bar
#. Navigation button to the 'Report a problem' help view
msgctxt "support-view"
msgid "Report a problem"
msgstr "Повідомити про проблему"

#. Button label for sending the problem report.
msgctxt "support-view"
msgid "Send"
msgstr "Надіслати"

#. Button label for sending the problem report without an email address.
msgctxt "support-view"
msgid "Send anyway"
msgstr "Усе одно надіслати"

msgctxt "support-view"
msgid "Sending..."
msgstr "Надсилання…"

msgctxt "support-view"
msgid "Sent"
msgstr "Надіслано"

#. Title label in navigation bar
msgctxt "support-view"
msgid "Support"
msgstr "Підтримка"

msgctxt "support-view"
msgid "Thanks!"
msgstr "Дякуємо!"

msgctxt "support-view"
msgid "To assist you better, please write in English or Swedish and include which country you are connecting from."
msgstr "Щоб ми могли швидше надати допомогу, напишіть нам англійською або шведською та вкажіть країну, з якої ви підключаєтесь."

msgctxt "support-view"
msgid "To help you more effectively, your app’s log file will be attached to this message. Your data will remain secure and private, as it is anonymised before being sent over an encrypted channel."
msgstr "Щоб допомога була ефективнішою, до цього повідомлення буде прикріплено файл журналу застосунку. Ваші дані залишаться захищеними й конфіденційними, оскільки вони анонімізуються і надсилаються зашифрованим каналом."

#. Button label for retrying problem report submission after a failure.
msgctxt "support-view"
msgid "Try again"
msgstr "Повторити"

#. Button label for updating the app to the latest version.
msgctxt "support-view"
msgid "Update app"
msgstr "Оновити застосунок"

#. Button label for opening app logs.
msgctxt "support-view"
msgid "View app logs"
msgstr "Переглянути журнали"

msgctxt "support-view"
msgid "We will look into this."
msgstr "Ми розглянемо цю проблему."

msgctxt "support-view"
msgid "You are about to send the problem report without a way for us to get back to you. If you want an answer to your report you will have to enter an email address."
msgstr "Ви збираєтеся надіслати звіт про проблему, не залишивши контактних даних. Якщо ви хочете отримати відповідь, введіть адресу електронної пошти."

msgctxt "support-view"
msgid "You are using an old version of the app. Please upgrade and see if the problem still exists before sending a report."
msgstr "Ви використовуєте стару версію застосунку. Перш ніж надсилати звіт, оновіть застосунок і перевірте, чи проблема не зникла."

msgctxt "support-view"
msgid "Your email (optional)"
msgstr "Ваша адреса ел. пошти (необов’язково)"

msgctxt "tray-icon-context-menu"
msgid "Disconnected from system service"
msgstr "Відключено від системної служби"

msgctxt "tray-icon-context-menu"
msgid "Open %(mullvadVpn)s"
msgstr "Відкрити %(mullvadVpn)s"

msgctxt "tray-icon-tooltip"
msgid "%(city)s, %(country)s"
msgstr "%(city)s, %(country)s"

msgctxt "tray-icon-tooltip"
msgid "Connected. %(location)s"
msgstr "Підключено. %(location)s"

msgctxt "tray-icon-tooltip"
msgid "Connecting. %(location)s"
msgstr "Підключення. %(location)s"

msgctxt "troubleshoot"
msgid "Disable split tunneling"
msgstr "Вимкнути роздільне тунелювання"

msgctxt "troubleshoot"
msgid "Enable “Full Disk Access” for “Mullvad VPN” in the macOS system settings."
msgstr "Увімкніть «Повний доступ до диска» для Mullvad VPN у системних налаштуваннях macOS."

msgctxt "troubleshoot"
msgid "Failed to enable split tunneling. This is because the app is missing system permissions. What you can do:"
msgstr "Не вдалося ввімкнути роздільне тунелювання: застосунку бракує системних дозволів. Що можна зробити:"

msgctxt "troubleshoot"
msgid "If these steps do not work please send a problem report."
msgstr "Якщо це не допоможе, надішліть звіт про проблему."

msgctxt "troubleshoot"
msgid "If you have installed another VPN then try to uninstall that."
msgstr "Якщо ви встановили інший VPN, спробуйте видалити його."

msgctxt "troubleshoot"
msgid "Make sure you have NF tables support."
msgstr "Переконайтесь, що у вас підтримується Nftables."

msgctxt "troubleshoot"
msgid "Open system settings"
msgstr "Відкрити налаштування системи"

msgctxt "troubleshoot"
msgid "This error can happen when something other than Mullvad is actively updating the DNS."
msgstr "Ця помилка може статись, коли сторонній застосунок (не Mullvad) активно оновлює DNS."

msgctxt "troubleshoot"
msgid "This might be caused by an outdated kernel."
msgstr "Причиною може бути застаріле ядро."

msgctxt "troubleshoot"
msgid "Try restarting your device."
msgstr "Спробуйте перезапустити пристрій."

msgctxt "troubleshoot"
msgid "Try to reinstall VMware."
msgstr "Спробуйте перевстановити VMware."

msgctxt "troubleshoot"
msgid "Try to turn Wi-Fi Calling off in the FaceTime app settings and restart the Mac."
msgstr "Спробуйте вимкнути Wi-Fi-виклики в налаштуваннях застосунку FaceTime і перезапустити Mac."

msgctxt "troubleshoot"
msgid "Try to uninstall VMware."
msgstr "Спробуйте видалити VMware."

msgctxt "troubleshoot"
msgid "Unable to communicate with the split tunnel driver."
msgstr "Не вдалося зв’язатися з драйвером роздільного тунелювання."

msgctxt "troubleshoot"
msgid "Unable to start tunnel connection because of a failure when creating the tunnel device. This is often caused by conflicts with the VMware Bridge Protocol."
msgstr "Не вдалося запустити тунельне підключення через збій під час створення тунельного пристрою. Часто причиною є конфлікти з VMware Bridge Protocol."

msgctxt "troubleshoot"
msgid "Uninstall or disable other DNS, networking and ads/website blocking apps."
msgstr "Видаліть або вимкніть інші DNS, мережеві застосунки й блокувальники реклами й сайтів."

msgctxt "troubleshoot"
msgid "Update your kernel."
msgstr "Оновіть ядро."

msgctxt "tunnel-control"
msgid "Connect"
msgstr "Підключити"

msgctxt "tunnel-control"
msgid "Switch location"
msgstr "Змінити розташування"

msgctxt "user-interface-settings-view"
msgid "Animate map"
msgstr "Анімувати карту"

msgctxt "user-interface-settings-view"
msgid "Animate map movements."
msgstr "Анімувати переміщення карти."

msgctxt "user-interface-settings-view"
msgid "Enable or disable system notifications. The critical notifications will always be displayed."
msgstr "Увімкнути або вимкнути системні сповіщення. Критичні сповіщення завжди показуватимуться."

msgctxt "user-interface-settings-view"
msgid "Enable to move the app around as a free-standing window."
msgstr "Дозволяє переміщувати застосунок як незакріплене вікно."

#. Navigation button to the 'Language' settings view
msgctxt "user-interface-settings-view"
msgid "Language"
msgstr "Мова"

msgctxt "user-interface-settings-view"
msgid "Monochromatic tray icon"
msgstr "Чорно-білий значок в області сповіщень"

msgctxt "user-interface-settings-view"
msgid "Notifications"
msgstr "Сповіщення"

msgctxt "user-interface-settings-view"
msgid "Show only the tray icon when the app starts."
msgstr "Під час запуску застосунку показувати лише значок в області сповіщень."

msgctxt "user-interface-settings-view"
msgid "Start minimized"
msgstr "Запускати згорнутим"

msgctxt "user-interface-settings-view"
msgid "Unpin app from taskbar"
msgstr "Відкріпити застосунок від панелі задач"

msgctxt "user-interface-settings-view"
msgid "Use a monochromatic tray icon instead of a colored one."
msgstr "Чорно-білий значок в області сповіщень замість кольорового."

#. Title label in navigation bar
msgctxt "user-interface-settings-view"
msgid "User interface settings"
msgstr "Налаштування інтерфейсу"

msgctxt "vpn-settings-view"
msgid "Add a server"
msgstr "Додати сервер"

#. Button label to add a private IP DNS server despite warning.
msgctxt "vpn-settings-view"
msgid "Add anyway"
msgstr "Усе одно додати"

#. Label for settings that enables ad blocking.
msgctxt "vpn-settings-view"
msgid "Ads"
msgstr "Реклама"

#. Label for settings that enables block of adult content.
msgctxt "vpn-settings-view"
msgid "Adult content"
msgstr "Контент для дорослих"

#. Label for list item that navigates to anti-censorship
#. settings view.
msgctxt "vpn-settings-view"
msgid "Anti-censorship"
msgstr "Обхід цензури"

msgctxt "vpn-settings-view"
msgid "Attention: enabling this will always require a Mullvad VPN connection in order to reach the internet."
msgstr "Увага: якщо ви активуєте цю опцію, доступ до Інтернету буде можливий лише через Mullvad VPN."

msgctxt "vpn-settings-view"
msgid "Attention: this setting cannot be used in combination with <b>%(customDnsFeatureName)s</b>"
msgstr "Увага: цей параметр і параметр <b>%(customDnsFeatureName)s</b> не можна використовувати разом"

msgctxt "vpn-settings-view"
msgid "Auto-connect"
msgstr "Автопідключення"

msgctxt "vpn-settings-view"
msgid "Automatically connect to a server when the app launches."
msgstr "Автоматично підключатися до сервера, коли запускається застосунок."

#. This is displayed when the custom DNS setting is turned on which makes the block
#. ads/trackers settings disabled. The text enclosed in "<b></b>" will appear bold.
#. Available placeholders:
#. %(customDnsFeatureName)s - The name displayed next to the custom DNS toggle.
msgctxt "vpn-settings-view"
msgid "Disable \"%(customDnsFeatureName)s\" below to activate these settings."
msgstr "Вимкніть параметр «%(customDnsFeatureName)s», щоб активувати ці налаштування."

#. This is displayed when either or both of the block ads/trackers settings are
#. turned on which makes the custom DNS setting disabled.
#. Available placeholders:
#. %(preferencesPageName)s - The page title showed on top in the preferences page.
msgctxt "vpn-settings-view"
msgid "Disable all <b>DNS content blockers</b> above to activate this setting."
msgstr "Вимкніть всі <b>DNS-блокувальники контенту</b>, щоб активувати цей параметр."

msgctxt "vpn-settings-view"
msgid "DNS content blockers"
msgstr "DNS-блокувальники контенту"

msgctxt "vpn-settings-view"
msgid "Enable to add at least one DNS server."
msgstr "Щоб додати хоча б один DNS-сервер, увімкніть цей параметр."

#. Description of in-tunnel IPv6 setting.
msgctxt "vpn-settings-view"
msgid "Enable to allow IPv6 traffic through the tunnel."
msgstr "Щоб дозволити передачу IPv6-трафіку через тунель, увімкніть цей параметр."

msgctxt "vpn-settings-view"
msgid "Enter IP"
msgstr "Введіть IP-адресу"

#. Label for settings that enables block of gamling related websites.
msgctxt "vpn-settings-view"
msgid "Gambling"
msgstr "Азартні ігри"

#. Title of in-tunnel IPv6 setting.
msgctxt "vpn-settings-view"
msgid "In-tunnel IPv6"
msgstr "IPv6 у тунелі"

msgctxt "vpn-settings-view"
msgid "IPv4 is always enabled and the majority of websites and applications use this protocol. We do not recommend enabling IPv6 unless you know you need it."
msgstr "IPv4 завжди ввімкнено. Більшість сайтів і застосунків використовують саме цей протокол. Не рекомендуємо вмикати IPv6 крім випадків, коли ви точно знаєте, що він вам потрібен."

#. A complimentary description for the setting Device IP version,
#. explaining why the user might want to configure the setting.
msgctxt "vpn-settings-view"
msgid "It can be useful when you are aware of problems caused by a certain IP version."
msgstr "Може бути корисно, коли ви знаєте про проблеми, спричинені певною версією IP."

msgctxt "vpn-settings-view"
msgid "It does this by allowing network communication outside the tunnel to local multicast and broadcast ranges as well as to and from these private IP ranges:"
msgstr "Це досягається завдяки дозволу мережевої взаємодії поза тунелем із локальними мультикастовими й широкомовними діапазонами, а також із цими діапазонами приватних IP-адрес:"

msgctxt "vpn-settings-view"
msgid "Kill switch"
msgstr "Аварійний вимикач"

msgctxt "vpn-settings-view"
msgid "Launch app on start-up"
msgstr "Автозапуск під час завантаження системи"

msgctxt "vpn-settings-view"
msgid "Local network sharing"
msgstr "Обмін даними в локальній мережі"

msgctxt "vpn-settings-view"
msgid "Lockdown mode"
msgstr "Режим блокування"

#. Label for settings that enables malware blocking.
msgctxt "vpn-settings-view"
msgid "Malware"
msgstr "Шкідливе ПЗ"

msgctxt "vpn-settings-view"
msgid "Server IP override"
msgstr "Перевизначення IP-адреси сервера"

#. Label for settings that enables block of social media.
msgctxt "vpn-settings-view"
msgid "Social media"
msgstr "Соцмережі"

msgctxt "vpn-settings-view"
msgid "The app’s built-in kill switch is always on. This setting will additionally block the internet if clicking Disconnect or Quit."
msgstr "Аварійний вимикач, вбудований у застосунок, завжди увімкнений. Цей параметр додатково блокує Інтернет у разі натискання на «Відключити» або «Вийти»."

msgctxt "vpn-settings-view"
msgid "The difference between the Kill Switch and Lockdown Mode is that the Kill Switch will prevent any leaks from happening during automatic tunnel reconnects, software crashes and similar accidents."
msgstr "Різниця між аварійним вимикачем і режимом блокування полягає в тому, що аварійний вимикач запобігає витокам у разі автоматичного перепідключення тунелю, збоїв ПЗ й інших подібних ситуацій."

msgctxt "vpn-settings-view"
msgid "The difference between the Kill Switch and Lockdown Mode is that the Kill Switch will prevent any leaks from happening during automatic tunnel reconnects, software crashes and similar accidents. With Lockdown Mode enabled, you must be connected to a Mullvad VPN server to be able to reach the internet. Manually disconnecting or quitting the app will block your connection."
msgstr "Різниця між аварійним вимикачем і режимом блокування полягає в тому, що аварійний вимикач запобігає витокам у разі автоматичного перепідключення тунелю, збоїв ПЗ й інших подібних ситуацій. Якщо у вас активовано режим блокування, ви маєте бути підключені до сервера Mullvad VPN, щоб отримати доступ до Інтернету. Ручне відключення або вихід із застосунку заблокує з’єднання."

msgctxt "vpn-settings-view"
msgid "The DNS server you want to add is a private IP. You must ensure that your network interfaces are configured to use it."
msgstr "DNS-сервер, який ви додаєте, є приватною IP-адресою. Переконайтеся, що ваші мережеві інтерфейси налаштовані для його використання."

msgctxt "vpn-settings-view"
msgid "This built-in feature prevents your traffic from leaking outside of the VPN tunnel if your network suddenly stops working or if the tunnel fails, it does this by blocking your traffic until your connection is reestablished."
msgstr "Ця вбудована функція запобігає витоку вашого трафіку за межі VPN-тунелю в разі раптового збою мережі або помилки тунелю. Вона робить це, блокуючи трафік до відновлення підключення."

msgctxt "vpn-settings-view"
msgid "This feature allows access to other devices on the local network, such as for sharing, printing, streaming, etc."
msgstr "Функція забезпечує доступ до інших пристроїв у локальній мережі, наприклад для обміну файлами, друку, потокового передавання тощо."

#. A description for the setting Device IP version,
#. explaining how the user can configure the setting.
msgctxt "vpn-settings-view"
msgid "This feature allows you to choose whether to use only IPv4, only IPv6, or allow the app to automatically decide the best option when connecting to a server."
msgstr "Ця функція дає змогу вибирати протокол, який використовується, — лише IPv4, лише IPv6 — або дозволити застосунку автоматично визначати найкращий варіант під час підключення до сервера."

msgctxt "vpn-settings-view"
msgid "This might cause issues on certain websites, services, and apps."
msgstr "Це може викликати проблеми під час використання певних вебсайтів, сервісів або застосунків."

#. Label for settings that enables tracker blocking.
msgctxt "vpn-settings-view"
msgid "Trackers"
msgstr "Трекери"

msgctxt "vpn-settings-view"
msgid "Use custom DNS server"
msgstr "Використовувати користувацький DNS-сервер"

#. Title label in navigation bar
msgctxt "vpn-settings-view"
msgid "VPN settings"
msgstr "Налаштування VPN"

msgctxt "vpn-settings-view"
msgid "Warning: The malware blocker is not an anti-virus and should not be treated as such, this is just an extra layer of protection."
msgstr "Увага: блокувальник шкідливого ПЗ не є антивірусом і не повинен сприйматися як такий — це лише додатковий рівень захисту."

msgctxt "vpn-settings-view"
msgid "When this feature is enabled it stops the device from contacting certain domains or websites known for distributing ads, malware, trackers and more."
msgstr "Коли ця функція ввімкнена, пристрій припиняє зв’язок із певними доменами або вебсайтами, які поширюють рекламу, шкідливі програми, трекери тощо."

msgctxt "vpn-settings-view"
msgid "When this feature is enabled, IPv6 can be used alongside IPv4 in the VPN tunnel to communicate with internet services."
msgstr "Коли ця функція ввімкнена, IPv6 може використовуватися разом з IPv4 у VPN-тунелі для зв’язку з інтернет-сервісами."

msgctxt "vpn-settings-view"
msgid "With Lockdown Mode enabled, you must be connected to a Mullvad VPN server to be able to reach the internet. Manually disconnecting or quitting the app will block your connection."
msgstr "Якщо у вас активовано режим блокування, ви маєте бути підключені до сервера Mullvad VPN, щоб отримати доступ до Інтернету. Ручне відключення або вихід із застосунку заблокує з’єднання."

#. Title label in navigation bar
msgctxt "wireguard-settings-nav"
msgid "Shadowsocks"
msgstr "Shadowsocks"

#. Title label in navigation bar
msgctxt "wireguard-settings-nav"
msgid "UDP-over-TCP"
msgstr "UDP-over-TCP"

msgctxt "wireguard-settings-view"
msgid "%(daita)s (%(daitaFull)s) hides patterns in your encrypted VPN traffic."
msgstr "%(daita)s (%(daitaFull)s) приховує патерни в зашифрованому VPN-трафіку."

msgctxt "wireguard-settings-view"
msgid "%(daita)s does this by carefully adding network noise and making all network packets the same size."
msgstr "Для цього %(daita)s додає мережевий шум й уніфікує розмір усіх пакетів."

msgctxt "wireguard-settings-view"
msgid "%(wireguard)s port"
msgstr "Порт %(wireguard)s"

#. Page title for WireGuard port view
msgctxt "wireguard-settings-view"
msgid "%(wireGuard)s port"
msgstr "Порт %(wireGuard)s"

msgctxt "wireguard-settings-view"
msgid "Attention: This increases network traffic and will also negatively affect speed, latency, and battery usage. Use with caution on limited plans."
msgstr "Увага: це збільшує мережевий трафік і негативно впливає на швидкість, збільшує затримки й зменшує час роботи батареї. Використовуйте обережно в разі обмежених тарифних планів."

msgctxt "wireguard-settings-view"
msgid "By enabling “%(directOnly)s” you will have to manually select a server that is %(daita)s-enabled. This can cause you to end up in a blocked state until you have selected a compatible server in the “Select location” view."
msgstr "Після ввімкнення параметра «%(directOnly)s» вам потрібно вручну вибрати сервер із підтримкою %(daita)s. До вибору сумісного сервера в розділі «Вибір розташування» ви можете бути заблоковані."

msgctxt "wireguard-settings-view"
msgid "By using sophisticated AI it’s possible to analyze the traffic of data packets going in and out of your device (even if the traffic is encrypted)."
msgstr "За допомогою складних алгоритмів ШІ можна аналізувати вхідний і вихідний трафік пакетів даних вашого пристрою (навіть якщо трафік зашифровано)."

msgctxt "wireguard-settings-view"
msgid "Cancel"
msgstr "Скасувати"

#. Title for device IP version setting.
msgctxt "wireguard-settings-view"
msgid "Device IP version"
msgstr "Версія IP на пристрої"

msgctxt "wireguard-settings-view"
msgid "If an observer monitors these data packets, %(daita)s makes it significantly harder for them to identify which websites you are visiting or with whom you are communicating."
msgstr "У разі моніторингу цих пакетів даних %(daita)s значно ускладнює визначення того, які вебсайти ви відвідуєте або з ким спілкуєтеся."

msgctxt "wireguard-settings-view"
msgid "It does this by performing an extra key exchange using a quantum safe algorithm and mixing the result into WireGuard’s regular encryption."
msgstr "Це досягається шляхом виконання додаткового обміну ключами з використанням квантово-стійкого алгоритму та інтеграції його результату в стандартне шифрування WireGuard."

#. The title for the WireGuard MTU setting. MTU stands for Maximum
#. Transmission Unit and controls the maximum size of packets sent over
#. the VPN tunnel.
msgctxt "wireguard-settings-view"
msgid "MTU"
msgstr "MTU"

msgctxt "wireguard-settings-view"
msgid "Multihop"
msgstr "Подвійний VPN"

msgctxt "wireguard-settings-view"
msgid "Multihop is being used to enable DAITA for your selected location"
msgstr "Подвійний VPN використовується, щоб увімкнути DAITA для вибраного розташування"

msgctxt "wireguard-settings-view"
msgid "Multihop routes your traffic into one WireGuard server and out another, making it harder to trace. This results in increased latency but increases anonymity online."
msgstr "Подвійний VPN спрямовує ваш трафік з одного сервера WireGuard на інший, що ускладнює відстеження. Це збільшує затримку, але підвищує анонімність в Інтернеті."

#. Warning text in a dialog that is displayed after a setting is toggled.
msgctxt "wireguard-settings-view"
msgid "Not all our servers are %(daita)s-enabled. In order to use the internet, you might have to select a new location after enabling."
msgstr "Не всі наші сервери підтримують %(daita)s. Щоб отримати доступ в Інтернет, вам, імовірно, доведеться вибрати нове розташування після ввімкнення цієї функції."

msgctxt "wireguard-settings-view"
msgid "Not all our servers are %(daita)s-enabled. Therefore, we use multihop automatically to enable %(daita)s with any server."
msgstr "Не всі наші сервери підтримують %(daita)s. Тому ми автоматично використовуємо подвійний VPN, щоб функція %(daita)s працювала з будь-яким сервером."

#. The title for the WireGuard port selector.
msgctxt "wireguard-settings-view"
msgid "Port"
msgstr "Порт"

#. Text showing currently selected port.
#. Available placeholders:
#. %(port)s - Can be either a number between 1 and 65535 or the text "Automatic".
msgctxt "wireguard-settings-view"
msgid "Port: %(port)s"
msgstr "Порт: %(port)s"

#. The title for the WireGuard quantum resistance selector. This setting
#. makes the cryptography resistant to the future abilities of quantum
#. computers.
msgctxt "wireguard-settings-view"
msgid "Quantum-resistant tunnel"
msgstr "Квантово-стійкий тунель"

#. The hint displayed below the WireGuard MTU input field.
#. Available placeholders:
#. %(wireguard)s - Will be replaced with the string "WireGuard"
#. %(max)d - the maximum possible wireguard mtu value
#. %(min)d - the minimum possible wireguard mtu value
msgctxt "wireguard-settings-view"
msgid "Set %(wireguard)s MTU value. Valid range: %(min)d - %(max)d."
msgstr "Установіть значення MTU для %(wireguard)s. Допустимий діапазон: %(min)d–%(max)d."

msgctxt "wireguard-settings-view"
msgid "Shadowsocks"
msgstr "Shadowsocks"

msgctxt "wireguard-settings-view"
msgid "The automatic setting will randomly choose from the valid port ranges shown below."
msgstr "В автоматичному режимі порт у випадковому порядку вибирається з допустимих діапазонів, зазначених нижче."

msgctxt "wireguard-settings-view"
msgid "The custom port can be any value inside the valid ranges: %(portRanges)s."
msgstr "Користувацький порт може мати будь-яке значення в межах дійсних діапазонів: %(portRanges)s."

msgctxt "wireguard-settings-view"
msgid "This feature makes the WireGuard tunnel resistant to potential attacks from quantum computers."
msgstr "Ця функція робить тунель WireGuard стійким до потенційних атак із використанням квантових комп’ютерів."

msgctxt "wireguard-settings-view"
msgid "UDP-over-TCP"
msgstr "UDP-over-TCP"

#. Text describing the valid port range for a port selector.
msgctxt "wireguard-settings-view"
msgid "Valid range: %(min)s - %(max)s"
msgstr "Допустимий діапазон: %(min)s–%(max)s"

#. Text describing the valid port ranges for a port selector.
#. Available placeholders:
#. %(portRanges)s - will be replaced with a comma-separated list of port ranges
msgctxt "wireguard-settings-view"
msgid "Valid ranges: %(portRanges)s"
msgstr "Допустимі діапазони: %(portRanges)s"

msgctxt "wireguard-settings-view"
msgid "Which TCP port the UDP-over-TCP obfuscation protocol should connect to on the VPN server."
msgstr "TCP-порт, до якого повинен підключатися протокол обфускації UDP-over-TCP на VPN-сервері."

