msgid "%(suggestedUpgradeVersion)s is ready to be installed."
msgstr "%(suggestedUpgradeVersion)s: готово до інсталяції."

msgctxt "in-app-notifications"
msgid "<a>%(lockdownModeSettingName)s</a> is enabled. Please click “Connect“ or disable “%(lockdownModeSettingName)s“ to unblock internet."
msgstr "<a>%(lockdownModeSettingName)s</a> увімкнено. Натисніть «Підключити» або вимкніть «%(lockdownModeSettingName)s», щоб розблокувати Інтернет."

msgctxt "in-app-notifications"
msgid "ACCOUNT CREDIT EXPIRES SOON"
msgstr "ЗАКІНЧУЄТЬСЯ БАЛАНС ОБЛІКОВОГО ЗАПИСУ"

