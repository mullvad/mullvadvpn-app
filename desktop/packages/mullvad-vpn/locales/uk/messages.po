msgid "Clicking “%(save)s” changes the in use method."
msgstr "Натиснувши «%(save)s», ви зміните метод, що використовується."

msgctxt "api-access-methods-view"
msgid "Delete %(name)s?"
msgstr "Видалити метод «%(name)s»?"

msgctxt "api-access-methods-view"
msgid "Edit method"
msgstr "Редагування методу"

msgctxt "api-access-methods-view"
msgid "Editing an API access method also tests it."
msgstr "Під час редагування нового методу доступу до API також виконується його перевірка."

msgctxt "api-access-methods-view"
msgid "Enter IP"
msgstr "Введіть IP-адресу"

msgctxt "api-access-methods-view"
msgid "Enter name"
msgstr "Введіть ім’я"

msgctxt "api-access-methods-view"
msgid "Enter port"
msgstr "Введіть порт"

msgctxt "api-access-methods-view"
msgid "If you are not connected to our VPN, then the Encrypted DNS proxy will use your own non-VPN IP when connecting. The DoH servers are hosted by one of the following providers: Quad9 or Cloudflare."
msgstr "Якщо ви не підключені до нашого VPN, то метод «Проксі через зашифрований DNS» використовуватиме вашу власну IP-адресу без VPN під час підключення. Сервери DoH розміщені в одного з таких провайдерів: Quad9 або Cloudflare."

msgctxt "api-access-methods-view"
msgid "In use"
msgstr "Використовується"

msgctxt "api-access-methods-view"
msgid "Local SOCKS5 server"
msgstr "Локальний сервер SOCKS5"

msgctxt "api-access-methods-view"
msgid "Manage and add custom methods to access the Mullvad API."
msgstr "Додавайте користувацькі методи доступу до Mullvad API і керуйте ними."

msgctxt "api-access-methods-view"
msgid "On some networks, where various types of censorship are being used, the API servers might not be directly reachable."
msgstr "У деяких мережах, де використовують різні типи цензури, може не бути прямого доступу до серверів API."

msgctxt "api-access-methods-view"
msgid "Please enter a valid IPv4 or IPv6 address."
msgstr "Введіть дійсну адресу IPv4 або IPv6."

msgctxt "api-access-methods-view"
msgid "Please enter a valid localhost port."
msgstr "Введіть дійсний порт localhost."

msgctxt "api-access-methods-view"
msgid "Please enter a valid remote server port."
msgstr "Введіть дійсний порт віддаленого сервера."

msgctxt "api-access-methods-view"
msgid "Please select a name for the access method not already in use."
msgstr "Введіть ім’я методу доступу, яке ще не використовується."

