msgstr "ЗАСТОСУНОК НЕ СИНХРОНІЗОВАНО"

msgctxt "in-app-notifications"
msgid "BETA UPDATE AVAILABLE"
msgstr "ДОСТУПНА БЕТА-ВЕРСІЯ"

msgctxt "in-app-notifications"
msgid "BLOCKING INTERNET"
msgstr "ІНТЕРНЕТ ЗАБЛОКОВАНО"

#. Notification subtitle when the app upgrade is ready to install.
msgctxt "in-app-notifications"
msgid "Click here to install update."
msgstr "Натисніть тут, щоб установити оновлення."

#. Notification subtitle when the installer failed.
msgctxt "in-app-notifications"
msgid "Click here to retry"
msgstr "Натисніть тут, щоб повторити спробу"

