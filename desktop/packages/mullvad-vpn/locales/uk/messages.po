msgid "(%d)"
msgstr "(%d)"

msgid "1. After clicking on the \"Go to VPN settings\" button below, click on the cogwheel next to the \"Mullvad VPN\" name."
msgstr "1. Після натискання кнопки «До налаштувань VPN» нижче натисніть значок шестерні поруч із пунктом Mullvad VPN."

msgid "2. To enable Auto-connect, click on the toggle next to \"Always-on VPN\"."
msgstr "2. Щоб увімкнути автопідключення, натисніть перемикач поруч із пунктом «Завжди увімкнений VPN»."

msgid "3. To enable Lockdown mode, click on the toggle next to \"Block connections without VPN\".<br /><br /><b>Warning: This setting blocks split apps and the Local Network Sharing feature.</b>"
msgstr "3. Щоб увімкнути режим блокування, натисніть перемикач поряд із пунктом «Блокувати з’єднання без VPN».<br /><br /><b>Увага: цей параметр блокує застосунки, до яких застосовано роздільне тунелювання, і функцію «Обмін даними в локальній мережі».</b>"

msgid "30 days was added to your account."
msgstr "На баланс облікового запису додано 30 днів."

msgid "90 days was added to your account."
msgstr "На баланс облікового запису додано 90 днів."

msgid "<b>Account recovery will not be possible.</b>"
msgstr "<b>Відновлення облікового запису буде неможливим.</b>"

msgid "<b>Attention:</b> Only some servers support the full port range."
msgstr "<b>Увага:</b> повний діапазон портів підтримують лише деякі сервери."

msgid "<b>Attention:</b> The app will close automatically and needs to be manually opened again after selecting a new icon and title. This will not impact your VPN connection."
msgstr "<b>Увага:</b> після вибору нового значка й назви застосунок автоматично закриється і повинен бути ввімкнений вручну. Це не вплине на ваше VPN-з’єднання."

msgid "<b>Please note that these methods do not improve performance, and may increase system utilization and battery consumption.</b>"
msgstr "<b>Зауважте, що ці методи не покращують продуктивності й можуть збільшити навантаження на систему та споживання заряду батареї.</b>"

msgid "<b>This action cannot be undone.</b>"
msgstr "<b>Цю дію не можна скасувати.</b>"

msgid "<b>Warning:</b>"
msgstr "<b>Увага:</b>"

msgid "<b>You will lose access to this account on all devices.</b>"
msgstr "<b>Ви втратите доступ до цього облікового запису на всіх пристроях.</b>"

msgid "API reachable, adding method..."
msgstr "Є доступ до API, додаємо метод…"

msgid "API unreachable, save method anyway?"
msgstr "Немає доступу до API. Усе одно зберегти метод?"

msgid "Account credit expires in a few minutes"
msgstr "Баланс облікового запису закінчується за кілька хвилин"

msgid "Account deleted"
msgstr "Обліковий запис видалено"

msgid "Account number is too long, please enter a valid number"
msgstr "Задовгий номер облікового запису, введіть дійсний номер"

msgid "Account number must match"
msgstr "Номер облікового запису має збігатись"

msgid "Account recovery will not be possible."
msgstr "Відновлення облікового запису буде неможливим."

msgid "Account time reminders"
msgstr "Нагадування про час, який залишився"

msgid "Add 30 days time (%s)"
msgstr "Додати 30 днів (%s)"

msgid "Add 90 days time (%s)"
msgstr "Додати 90 днів (%s)"

msgid "Add DNS server"
msgstr "Додати DNS-сервер"

