{
  "sourceLanguage" : "en",
  "strings" : {
    "Disable “%@” or disconnect before updating in order not to lose network connectivity." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deaktiver \"%@\" eller afbryd forbindelsen før opdatering for ikke at miste netværksforbindelsen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deaktivieren Sie „%@“ oder trennen Sie die Verbindung vor dem Update, um die Netzwerkverbindung nicht zu verlieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deshabilite «%@» o desconéctelo antes de actualizar para no perder conectividad de red."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poista \"%@\" käytöstä tai katkaise sen yhteys ennen päivittämistä, jotta et menetä verkkoyhteyttä."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Désactivez « %@ » ou déconnectez-vous avant d'effectuer la mise à jour pour éviter de perdre la connectivité au réseau."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Disabilita “%@” o disconnettiti prima dell’aggiornamento per non perdere la connettività di rete."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ネットワーク接続を失わないようにするには、更新前に「%@」を無効にするか、切断してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "네트워크 연결 해제를 방지하려면 업데이트 전에 \"%@\" 기능을 비활성화하거나 연결을 해제하세요."
          }
        },
        "my" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ကွန်ရက် ချိတ်ဆက်မှု မဆုံးရှုံးစေရန် အပ်ဒိတ်မလုပ်မီ “%@” ကို ပိတ်ပါ သို့မဟုတ် ချိတ်ဆက်မှု ဖြုတ်ပါ။"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deaktiver «%@» eller koble fra før du oppdaterer for å sikre at du ikke mister nettverksforbindelsen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schakel \"%@\" uit of verbreek de verbinding voordat u bijwerkt om de netwerkconnectiviteit niet te verliezen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wyłącz „%@” lub rozłącz się przed aktualizacją, aby nie utracić łączności z siecią."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Desative “%@” ou desligue antes de atualizar para não perder a ligação de rede."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Отключите «%@» или разорвите соединение перед обновлением, чтобы не потерять сетевое подключение."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inaktivera \"%@\" eller koppla från innan du uppdaterar så att inte nätverksanslutningen bryts."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ปิดใช้งาน “%@” หรือตัดการเชื่อมต่อก่อนอัปเดต เพื่อป้องกันไม่ให้สูญเสียการเชื่อมต่อเครือข่าย"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ağ bağlantısını kaybetmemek için \"%@\" özelliğini devre dışı bırakın veya bağlantıyı kesin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更新前停用“%@”或断开连接，以免网络连接断开。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "更新前，請停用「%@」或中斷連線，以避免網路連線中斷。"
          }
        }
      }
    },
