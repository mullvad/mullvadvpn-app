# Maintainer: Tritao <274685803+tritaum@users.noreply.github.com>
pkgbase=patched-mullvad-vpn-bin
pkgname=(
  'patched-mullvad-vpn-bin'
  'patched-mullvad-vpn-daemon-bin'
)
pkgver=2026.2.beta1
pkgrel=1
_appver=${pkgver/.beta/-beta}
pkgdesc="Unofficial patched Mullvad VPN client app"
arch=('x86_64' 'aarch64')
url="https://github.com/tritaum/ip-split-tunneling-mullvad"
license=('GPL-3.0-or-later')
depends=(
  'alsa-lib'
  'gtk3'
  'iputils'
  'libnftnl'
  'libnotify'
  'nss'
)
source=('patched-mullvad-vpn.sh')
source_x86_64=("$url/releases/download/$_appver/MullvadVPN-${_appver}_amd64.deb")
source_aarch64=("$url/releases/download/$_appver/MullvadVPN-${_appver}_arm64.deb")
sha256sums=('a59c29f07b4eab9af56f0e8be42bae0d83726f5185e88de0c5a48f4098c3c0a4')
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

prepare() {
  mkdir -p "MullvadVPN-$_appver"
  bsdtar -xvf data.tar.xz -C "MullvadVPN-$_appver"
}

package_patched-mullvad-vpn-bin() {
  pkgdesc+=" (desktop application)"
  depends+=('patched-mullvad-vpn-daemon-bin')
  optdepends=('libappindicator: tray icon')
  provides=('mullvad-vpn')
  conflicts=('mullvad-vpn' 'mullvad-vpn-bin' 'patched-mullvad-vpn')
  install='patched-mullvad-vpn.install'

  bsdtar -xvf data.tar.xz -C "$pkgdir/"
  chmod 4755 "$pkgdir/opt/Mullvad VPN/chrome-sandbox"

  rm -f "$pkgdir/usr/share/doc/mullvad-vpn/changelog.gz"
  ln -sf "/opt/Mullvad VPN/resources/CHANGELOG.md" "$pkgdir/usr/share/doc/mullvad-vpn/"

  rm -rf "$pkgdir/usr/bin/"
  rm -f "$pkgdir/opt/Mullvad VPN"/resources/{ca.crt,mullvad-{problem-report,setup},relays.json}
  rm -rf "$pkgdir"/usr/{lib,local,share/{bash-completion,fish,zsh}}/

  install -Dm755 "$srcdir/patched-mullvad-vpn.sh" "$pkgdir/usr/bin/patched-mullvad-vpn"

  install -d "$pkgdir/etc/apparmor.d"
  ln -s "/opt/Mullvad VPN/resources/apparmor_mullvad" "$pkgdir/etc/apparmor.d/mullvad"
}

package_patched-mullvad-vpn-daemon-bin() {
  pkgdesc+=" (daemon and CLI)"
  depends=(
    'dbus'
    'iputils'
    'libnftnl'
  )
  provides=('mullvad-vpn-daemon')
  conflicts=('mullvad-vpn-daemon' 'mullvad-vpn-daemon-bin' 'patched-mullvad-vpn-daemon')
  install='patched-mullvad-vpn-daemon.install'

  cd "MullvadVPN-$_appver"
  install -Dm755 usr/bin/{mullvad,mullvad{-daemon,-exclude}} -t "$pkgdir/usr/bin/"
  install -Dm755 "opt/Mullvad VPN"/resources/mullvad{-problem-report,-setup} -t \
    "$pkgdir/opt/Mullvad VPN/resources/"
  ln -s "/opt/Mullvad VPN/resources/mullvad-problem-report" "$pkgdir/usr/bin/"
  install -Dm644 "opt/Mullvad VPN"/resources/ca.crt -t "$pkgdir/opt/Mullvad VPN/resources/"
  install -Dm644 "opt/Mullvad VPN"/resources/relays.json -t "$pkgdir/opt/Mullvad VPN/resources/"
  install -Dm644 usr/lib/systemd/system/mullvad{-daemon,-early-boot-blocking}.service -t \
    "$pkgdir/usr/lib/systemd/system/"
  install -Dm644 usr/share/bash-completion/completions/mullvad -t \
    "$pkgdir/usr/share/bash-completion/completions/"
  install -Dm644 usr/share/fish/vendor_completions.d/mullvad.fish -t \
    "$pkgdir/usr/share/fish/vendor_completions.d/"
  install -Dm644 usr/local/share/zsh/site-functions/_mullvad -t \
    "$pkgdir/usr/share/zsh/site-functions/"
}
