#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "usage: $0 <patched-mullvad-vpn-daemon-bin>" >&2
  exit 2
fi

pkgbase=$1

case "$pkgbase" in
  patched-mullvad-vpn-daemon-bin) ;;
  *)
    echo "unknown AUR package base: $pkgbase" >&2
    exit 2
    ;;
esac

repo_root=$(git rev-parse --show-toplevel)
pkg_dir="$repo_root/packaging/aur/$pkgbase"

if [[ ! -f "$pkg_dir/.SRCINFO" ]]; then
  echo "$pkg_dir/.SRCINFO is missing. Run packaging/aur/scripts/update-srcinfo $pkgbase first." >&2
  exit 1
fi

work_dir="${AUR_PUBLISH_DIR:-$repo_root/.build/aur-publish/$pkgbase}"
remote="${AUR_REMOTE:-ssh://aur@aur.archlinux.org/$pkgbase.git}"

# Prepare SSH command with proper quoting
ssh_cmd="ssh -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new"
if [[ -n "${AUR_SSH_KEY:-}" ]]; then
  ssh_cmd="$ssh_cmd -i $AUR_SSH_KEY"
fi

rm -rf "$work_dir"
GIT_SSH_COMMAND="$ssh_cmd" git clone "$remote" "$work_dir"

rsync -a --delete \
  --exclude '.git' \
  "$pkg_dir"/ "$work_dir"/

cd "$work_dir"

# Configure git identity for this repository if provided
if [[ -n "${AUR_GIT_EMAIL:-}" ]]; then
  git config user.email "$AUR_GIT_EMAIL"
fi
if [[ -n "${AUR_GIT_NAME:-}" ]]; then
  git config user.name "$AUR_GIT_NAME"
fi

if [[ -z "$(git status --porcelain)" ]]; then
  echo "No AUR changes to publish for $pkgbase."
  exit 0
fi

git add .
git commit -m "Update $pkgbase"
GIT_SSH_COMMAND="$ssh_cmd" git push origin HEAD:master
