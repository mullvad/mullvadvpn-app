#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "usage: $0 <patched-mullvad-vpn-daemon-bin> [makepkg args...]" >&2
  exit 2
fi

pkgbase=$1
shift

case "$pkgbase" in
  patched-mullvad-vpn-daemon-bin) ;;
  *)
    echo "unknown AUR package base: $pkgbase" >&2
    exit 2
    ;;
esac

if ! command -v makepkg >/dev/null 2>&1; then
  echo "makepkg is required. Run this on Arch Linux with base-devel installed." >&2
  exit 127
fi

repo_root=$(git rev-parse --show-toplevel)
src_dir="$repo_root/packaging/aur/$pkgbase"
build_dir="${AUR_BUILD_DIR:-$repo_root/.build/aur/$pkgbase}"

rm -rf "$build_dir"
mkdir -p "$build_dir"
cp -a "$src_dir"/. "$build_dir"/

cd "$build_dir"
makepkg --syncdeps --cleanbuild --clean "$@"
